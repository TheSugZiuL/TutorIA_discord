{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tutor-monitor-status",
  "main": "./monitor-dashboard/src/index.js",
  "compatibility_date": "2026-05-13",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./monitor-dashboard/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
