{
  "name": "discord-tutor-bot",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.16"
  },
  "scripts": {
    "dev": "tsx src/bot.ts",
    "register": "tsx src/register-commands.ts",
    "register:dist": "node dist/register-commands.js",
    "diagnose": "tsx src/diagnose-discord.ts",
    "diagnose:dist": "node dist/diagnose-discord.js",
    "db:status": "tsx src/diagnose-database.ts",
    "db:status:dist": "node dist/diagnose-database.js",
    "build": "tsc",
    "start": "node dist/bot.js"
  },
  "dependencies": {
    "discord.js": "latest",
    "dotenv": "latest",
    "openai": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
